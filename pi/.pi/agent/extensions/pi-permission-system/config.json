{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",

  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": false,
  "piInfrastructureReadPaths": [
    "~/Library/**/node_modules/@earendil-works/pi-coding-agent/**"
  ],

  "permission": {
    "*": "ask",

    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.ssh/*": "deny"
    },

    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",

    "kb_read": "allow",
    "session_search": "allow",
    "session_read": "allow",
    "memory_search": "allow",
    "memory_remember": "allow",
    "memory_stats": "allow",
    "memory_lessons": "allow",
    "memory_forget": "allow",
    "subagents": "allow",
    "subagent": "allow",
    "intercom": "allow",

    "bash": {
      "*": "ask",
      "true": "allow",
      "false": "allow",
      ".agents/skills/pr-summary/scripts/pr-diff.sh *": "allow",
      ".agents/skills/standup-summary/scripts/collect-standup-git-history.sh *": "allow",
      "/usr/bin/time *": "allow",

      "ls *": "allow",
      "cd *": "allow",
      "pwd *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "file *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "nl *": "allow",
      "sed -n *": "allow",
      "sed * > *": "ask",
      "sed -i *": "ask",

      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git branch *": "allow",
      "git ls-files *": "allow",
      "git rev-parse *": "allow",
      "git fetch *": "allow",
      "git push --force-with-lease": "ask",
      "git reset --hard": "ask",
      "git clean -fd": "ask",
      "git tag -d *": "ask",
      "git rebase -i *": "ask",
      "git stash clear": "ask",
      "git stash drop": "ask",
      "git push --force": "deny",
      "git push -f": "deny",
      "git push origin :*": "deny",
      "git push origin --delete *": "deny",
      "git reset --hard HEAD~*": "deny",
      "git clean -fdx": "deny",
      "git branch -D *": "deny",
      "git filter-branch *": "deny",
      "git filter-repo *": "deny",
      "git reflog expire --expire=now --all": "deny",

      "yarn tsx *": "allow",
      "yarn workspace *": "allow",
      "npm publish": "ask",
      "yarn publish": "ask",
      "npm run deploy": "ask",
      "yarn deploy": "ask",
      "yarn run *:prod": "ask",

      "DELETE FROM *": "ask",
      "ALTER TABLE * DROP COLUMN *": "ask",
      "DROP INDEX *": "ask",
      "DROP DATABASE *": "deny",
      "DROP TABLE *": "deny",
      "DROP SCHEMA *": "deny",
      "TRUNCATE TABLE *": "deny",
      "TRUNCATE *": "deny",

      "redis-cli CONFIG RESETSTAT": "ask",
      "dropdb *": "deny",
      "psql * -c \"DROP *\"": "deny",
      "mongo * --eval \"db.dropDatabase()\"": "deny",
      "redis-cli FLUSHALL": "deny",
      "redis-cli FLUSHDB": "deny",

      "npx prisma migrate reset": "deny",
      "npx prisma db push --force-reset": "deny",
      "npx sequelize-cli db:drop": "deny",
      "npx typeorm schema:drop": "deny",

      "docker network rm *": "ask",
      "docker-compose rm -f": "ask",
      "docker rm -f *": "deny",
      "docker rmi -f *": "deny",
      "docker system prune -a": "deny",
      "docker volume rm *": "deny",
      "docker volume prune": "deny",
      "docker-compose down -v": "deny",

      "terraform destroy": "ask",
      "aws s3 rb s3://* --force": "deny",
      "aws s3 rm s3://* --recursive": "deny",
      "az group delete *": "deny",
      "gcloud * delete": "deny",
      "terraform destroy -auto-approve": "deny",

      "cat * > .env": "ask",
      "unset *": "ask",
      "history -c": "ask",
      "rm .env*": "deny",
      "rm *.env": "deny",

      "find . -name * -delete": "ask",
      "rm -f *": "ask",
      "kill -9 *": "ask",
      "pkill -9 *": "ask",
      "killall *": "ask",
      "chmod -R 777 *": "ask",
      "chown -R * /": "deny",
      "sudo rm *": "deny",
      "sudo dd *": "deny",
      "rm -rf *": "deny",
      "rm -rf /": "deny",
      "rm -rf .": "deny",
      "find . -delete": "deny",
      "> *": "deny",
      "truncate -s 0 *": "deny",
      "dd if=/dev/zero of=*": "deny",
      "mv * /dev/null": "deny",
      "cp /dev/null *": "deny",
      "shred -u *": "deny",
      "mkfs.*": "deny",
      "fdisk *": "deny",
      ":(){:|:&};:": "deny"
    },
    "mcp": {
      "mcp_status": "allow"
    },
    "skill": {
      "*": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.ssh/*": "deny"
    }
  }
}
